.vercel

# local sqlite db (contains password hashes/sessions — never commit this)
/data

# user-uploaded photos — these belong on the deploy target's persistent
# volume, not in git. Keep the folder itself so `public/uploads` still
# exists for local dev before anyone's uploaded anything.
/public/uploads/*
!/public/uploads/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts